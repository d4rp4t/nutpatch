{
  "name": "nutpatch",
  "version": "0.0.1",
  "description": "nutpatch",
  "main": "lib/index",
  "module": "lib/index",
  "types": "lib/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts",
      "react-native": "./src/index.ts"
    },
    "./core": {
      "import": "./lib/crypto/core.js",
      "require": "./lib/crypto/core.js",
      "types": "./lib/crypto/core.d.ts",
      "react-native": "./src/crypto/core.ts"
    },
    "./NUT12": {
      "import": "./lib/crypto/NUT12.js",
      "require": "./lib/crypto/NUT12.js",
      "types": "./lib/crypto/NUT12.d.ts",
      "react-native": "./src/crypto/NUT12.ts"
    }
  },
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "android/build.gradle",
    "android/gradle.properties",
    "android/fix-prefab.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "cpp",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "app.plugin.js",
    "nitro.json",
    "*.podspec",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf android/build node_modules/**/android/build lib",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"**/*.{js,ts,tsx}\" --fix",
    "lint-ci": "ESLINT_USE_FLAT_CONFIG=false eslint \"**/*.{js,ts,tsx}\" -f @jamesacarr/github-actions",
    "typescript": "tsc",
    "specs": "tsc --noEmit false && nitrogen --logLevel=\"debug\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "react-native",
    "nitro"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrousavy/nitro.git"
  },
  "author": "Marc Rousavy <me@mrousavy.com> (https://github.com/mrousavy)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mrousavy/nitro/issues"
  },
  "homepage": "https://github.com/mrousavy/nitro#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@cashu/cashu-ts": "^4.0.0-rc4",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@react-native/eslint-config": "0.83.0",
    "@types/react": "^19.1.03",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "nitrogen": "*",
    "prettier": "^3.3.3",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-nitro-modules": "*",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "@cashu/cashu-ts": "^4.0.0-rc4",
    "@noble/curves": ">=1.0.0",
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*",
    "typescript": "^5.8.3"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@react-native",
      "prettier"
    ],
    "plugins": [
      "prettier"
    ],
    "rules": {
      "prettier/prettier": [
        "warn",
        {
          "quoteProps": "consistent",
          "singleQuote": true,
          "tabWidth": 2,
          "trailingComma": "es5",
          "useTabs": false
        }
      ]
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  }
}
